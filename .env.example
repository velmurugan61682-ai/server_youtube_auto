# Server Configuration
PORT=5000
MONGODB_URI=your_mongodb_uri

JWT_SECRET=your_jwt_secret

# Google / YouTube API Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
REDIRECT_URI=https://server-youtube-automation.onrender.com/api/youtube/callback
YOUTUBE_API_KEY=your_youtube_api_key

# OpenAI / DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key

# GoWhats WhatsApp API Configuration
GOWHATS_API_KEY=your_gowhats_api_key
GOWHATS_API_URL=https://bot.gowhats.in/api/v1/messages/send
PRODUCT_LINK=https://your-product-link.com

# Client Configuration (for CORS)
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# YouTube Auto-Reply & Moderation Automation Settings
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

YOUTUBE_OAUTH_REFRESH_TOKEN=your_youtube_oauth_refresh_token
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
MY_WHATSAPP_NUMBER=your_whatsapp_number


