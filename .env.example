# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
MONGODB_URI=your_mongodb_uri_here

# JWT Token Secret
JWT_SECRET=your_jwt_secret_here

# Google/YouTube OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/youtube/callback
GOOGLE_REDIRECT_URI_DEV=http://localhost:5000/api/youtube/callback
GOOGLE_REDIRECT_URI_PROD=your_production_redirect_uri_here

# Client App URLs
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173/dashboard

# YouTube API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Deepseek AI Integration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GoWhats (WhatsApp API Provider) Configurations
GOWHATS_API_KEY=your_gowhats_api_key_here
GOWHATS_API_URL=https://bot.gowhats.in/api/v1/orders
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Payment Gateways (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Single Sign On (SSO) Keys
DEV_SSO_KEY=your_dev_sso_key_here
PRODUCT_LINK=your_product_link_here
