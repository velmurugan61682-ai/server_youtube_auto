# Server Configuration
PORT=5000
MONGODB_URI=your_mongodb_uri_here

JWT_SECRET=your_jwt_secret_here

# Google / YouTube API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=https://server-youtube-automation.onrender.com/api/youtube/callback
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GoWhats WhatsApp API Configuration
GOWHATS_API_KEY=your_gowhats_api_key_here
GOWHATS_API_URL=https://bot.gowhats.in/api/v1/messages/send
PRODUCT_LINK=https://your-product-link.com

# Client Configuration (for CORS)
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# YouTube Auto-Reply & Moderation Automation Settings
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here


YOUTUBE_OAUTH_REFRESH_TOKEN=
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
MY_WHATSAPP_NUMBER=your_whatsapp_number_here

# YouTube Auto DM Configuration
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
