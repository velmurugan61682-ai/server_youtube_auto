# Server Configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/youtube_mod
JWT_SECRET=your_jwt_secret_here

# Google / YouTube API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=http://localhost:5000/api/youtube/callback
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# GoWhats WhatsApp API Configuration
GOWHATS_API_KEY=your_gowhats_api_key_here
GOWHATS_API_URL=https://your-gowhats-api-url.com
PRODUCT_LINK=https://your-product-link.com

# Client Configuration (for CORS)
CLIENT_URL=http://localhost:5173
NODE_ENV=development
