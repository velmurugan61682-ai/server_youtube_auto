# ==============================================================================
#                      YOUTUBE AUTOMATION SERVER ENVIRONMENT CONFIG (EXAMPLE)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Server Configuration
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# CORS and Frontend redirection targets
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
VITE_FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# 2. Database Configuration
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/youtube_automation

# ------------------------------------------------------------------------------
# 3. Authentication (JWT & SSO)
# ------------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
ADMIN_JWT_SECRET=your_admin_jwt_secret
ENCRYPTION_KEY=your_32_plus_character_encryption_secret
ALLOW_ANY_VERCEL_ORIGIN=false
ALLOW_DEV_AUTO_LOGIN=false
ALLOW_DEV_ADMIN_RESET=false
ADMIN_RESET_EMAIL=admin@youtubeai.test
ADMIN_RESET_PASSWORD=change_me_before_running_reset
DEV_SSO_KEY=your_dev_sso_key_here

# ------------------------------------------------------------------------------
# 4. Google OAuth & YouTube API Configuration
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI_DEV=http://localhost:5000/api/youtube/callback
GOOGLE_REDIRECT_URI_PROD=https://your-production-server.com/api/youtube/callback

YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_youtube_channel_id
YOUTUBE_OAUTH_REFRESH_TOKEN=your_youtube_oauth_refresh_token

# ------------------------------------------------------------------------------
# 5. AI Services
# ------------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key

# External/Admin API access for integrations
EXTERNAL_ADMIN_API_KEY=your_external_admin_api_key
DEPLOY_ADMIN_CUSTOMER_DETAILS_API_URL=https://your-production-server.com/api/v1/admin/customers/details
LOCAL_ADMIN_CUSTOMER_DETAILS_API_URL=http://localhost:5000/api/v1/admin/customers/details
DEPLOY_CUSTOMER_DETAILS_API_URL=https://your-production-server.com/api/external/customers/details
LOCAL_CUSTOMER_DETAILS_API_URL=http://localhost:5000/api/external/customers/details

# ------------------------------------------------------------------------------
# 6. Payment & Subscriptions (Razorpay)
# ------------------------------------------------------------------------------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Optional: Custom Subscription Plan IDs (defaults to plan_*_mock if not set)
# RAZORPAY_PLAN_ONE_RUPEE=
# RAZORPAY_PLAN_MONTHLY_345=
# RAZORPAY_PLAN_TWO_MONTHS_600=
# RAZORPAY_PLAN_THREE_MONTHS_999=
# RAZORPAY_PLAN_PROFESSIONAL=

# ------------------------------------------------------------------------------
# 7. WhatsApp & Gowhats Alert Services
# ------------------------------------------------------------------------------
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
MY_WHATSAPP_NUMBER=your_own_phone_number_with_country_code

GOWHATS_API_KEY=your_gowhats_api_key
GOWHATS_API_URL=https://bot.gowhats.in/api/v1/orders

# ------------------------------------------------------------------------------
# 8. Miscellaneous / Marketing
# ------------------------------------------------------------------------------
PRODUCT_LINK=https://channelbot.in
